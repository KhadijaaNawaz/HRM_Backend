{
	"info": {
		"_postman_id": "hrm-saas-complete-v2",
		"name": "HRM SaaS API - Complete Collection v2",
		"description": "Complete API collection for HRM SaaS multi-tenant system. Includes ALL endpoints: Platform Admin, Authentication, Password Management, User Management, Role Management, Invitations, Organization, Attendance, and Audit Logs.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
