							"port": "8000",
							"path": ["{{apiVersion}}", "users", "{{userId}}", ""]
						}
					},
					"response": []
				},
				{
					"name": "Update User (PATCH)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{tenantAccessToken}}",
									"type": "string"
								}
							]
						},
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
