# ============================================================================
# HRM SAAS - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and update with your actual values
# For Docker deployment, most values will be set by docker-compose.yml
# ============================================================================

# ----------------------------------------------------------------------------
# Django Core Settings
# ----------------------------------------------------------------------------

# IMPORTANT: Generate a secure secret key for production
# Use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-change-this-in-production-generate-new-key

# DEBUG: Set to False in production
DEBUG=True

# ALLOWED_HOSTS: Comma-separated list of valid hosts
# For Docker/deployment, include your domain names
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# ----------------------------------------------------------------------------

# For Docker deployment, these will be set by docker-compose.yml
# DB_HOST=db, DB_PORT=5432
DB_NAME=hrm_saas
DB_USER=hrm_saas
DB_PASSWORD=change-this-strong-password
DB_HOST=localhost
DB_PORT=5432

# ----------------------------------------------------------------------------
# CORS Settings
# ----------------------------------------------------------------------------

# Comma-separated list of allowed origins for development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000

# Allow all origins (NOT recommended for production)
CORS_ALLOW_ALL_ORIGINS=True

# ----------------------------------------------------------------------------
# Celery Configuration (Background Tasks)
# ----------------------------------------------------------------------------

# For Docker deployment, use: redis://redis:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ----------------------------------------------------------------------------
# HRM SaaS Application Settings
# ----------------------------------------------------------------------------

# Enable public tenant signup (set to True to allow anyone to create an organization)
PUBLIC_SIGNUP_ENABLED=False

# Frontend URL (for email links, redirects, etc.)
FRONTEND_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Email Configuration (Required for invitations & password resets)
# ----------------------------------------------------------------------------

# Options: console.EmailBackend (development), smtp.EmailBackend (production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP Configuration (required when using smtp.EmailBackend)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@hrmsaas.com

# For production, consider using:
# - SendGrid (django-sendgrid-v5)
# - AWS SES (django-ses)
# - Mailgun (django-mailgun)

# ----------------------------------------------------------------------------
# JWT Settings (Optional - overrides defaults)
# ----------------------------------------------------------------------------

# Access token lifetime (default: 60 minutes)
# ACCESS_TOKEN_LIFETIME_MINUTES=60

# Refresh token lifetime (default: 7 days)
# REFRESH_TOKEN_LIFETIME_DAYS=7

# ----------------------------------------------------------------------------
# Deployment Settings (Optional)
# ----------------------------------------------------------------------------

# Static files configuration
# STATIC_ROOT=/app/staticfiles

# Media files configuration
# MEDIA_ROOT=/app/media

# Security settings for production (uncomment and configure for production)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
