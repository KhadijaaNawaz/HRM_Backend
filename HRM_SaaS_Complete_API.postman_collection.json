									"key": "token",
									"value": "{{adminAccessToken}}",
									"type": "string"
								}
							]
						},
						"method": "DELETE",
						"url": {
							"raw": "{{baseUrl}}/{{apiVersion}}/admin/tenants/{{organizationId}}/",
							"host": ["{{baseUrl}}"],
							"path": ["{{apiVersion}}", "admin", "tenants", "{{organizationId}}", ""]
						},
						"description": "Permanently delete a tenant and all associated data. Use with caution!"
					},
					"response": []
				},
				{
					"name": "Activate Tenant",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminAccessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/{{apiVersion}}/admin/tenants/{{organizationId}}/activate/",
							"host": ["{{baseUrl}}"],
							"path": ["{{apiVersion}}", "admin", "tenants", "{{organizationId}}", "activate", ""]
						}
					},
					"response": []
				},
				{
					"name": "Suspend Tenant",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminAccessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/{{apiVersion}}/admin/tenants/{{organizationId}}/suspend/",
							"host": ["{{baseUrl}}"],
							"path": ["{{apiVersion}}", "admin", "tenants", "{{organizationId}}", "suspend", ""]
						}
					},
					"response": []
				},
				{
					"name": "List Tenant Users",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminAccessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/{{apiVersion}}/admin/tenants/{{organizationId}}/users/",
							"host": ["{{baseUrl}}"],
							"path": ["{{apiVersion}}", "admin", "tenants", "{{organizationId}}", "users", ""]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "1. Authentication",
			"description": "Authentication endpoints for login, logout, token refresh",
			"item": [
				{
					"name": "Tenant Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.collectionVariables.set('tenantAccessToken', response.access);",
									"    pm.collectionVariables.set('refreshToken', response.refresh);",
									"    console.log('Login successful');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Host",
								"value": "{{tenantSubdomain}}.localhost:8000"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@acme.com\",\n    \"password\": \"TenantAdmin123!\"\n}"
						},
						"url": {
							"raw": "http://{{tenantSubdomain}}.localhost:8000/{{apiVersion}}/auth/login/",
							"host": ["{{tenantSubdomain}}.localhost"],
							"port": "8000",
							"path": ["{{apiVersion}}", "auth", "login", ""]
						},
						"description": "Login using tenant subdomain in Host header. Tenant is determined from subdomain."
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.collectionVariables.set('tenantAccessToken', response.access);",
									"    if (response.refresh) {",
									"        pm.collectionVariables.set('refreshToken', response.refresh);",
									"    }",
									"    console.log('Token refreshed');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/{{apiVersion}}/auth/token/refresh/",
							"host": ["{{baseUrl}}"],
							"path": ["{{apiVersion}}", "auth", "token", "refresh", ""]
						}
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{tenantAccessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Host",
								"value": "{{tenantSubdomain}}.localhost:8000"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "http://{{tenantSubdomain}}.localhost:8000/{{apiVersion}}/auth/logout/",
							"host": ["{{tenantSubdomain}}.localhost"],
							"port": "8000",
							"path": ["{{apiVersion}}", "auth", "logout", ""]
						},
						"description": "Logout user by blacklisting the refresh token"
					},
					"response": []
				},
				{
					"name": "Get Current User (Me)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{tenantAccessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "Host",
								"value": "{{tenantSubdomain}}.localhost:8000"
							}
						],
						"url": {
							"raw": "http://{{tenantSubdomain}}.localhost:8000/{{apiVersion}}/auth/me/",
							"host": ["{{tenantSubdomain}}.localhost"],
							"port": "8000",
							"path": ["{{apiVersion}}", "auth", "me", ""]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Password Management",
			"description": "Password reset and change endpoints",
			"item": [
				{
					"name": "Forgot Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Host",
								"value": "{{tenantSubdomain}}.localhost:8000"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"user@acme.com\",\n    \"redirect_url\": \"http://localhost:3000/reset-password\"\n}"
						},
						"url": {
							"raw": "http://{{tenantSubdomain}}.localhost:8000/{{apiVersion}}/auth/password/forgot/",
							"host": ["{{tenantSubdomain}}.localhost"],
							"port": "8000",
							"path": ["{{apiVersion}}", "auth", "password", "forgot", ""]
						},
						"description": "Request password reset email. Throttled to 5/hour per IP. Always returns success message (don't reveal email existence)."
					},
					"response": []
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"uid\": \"Mg\",\n    \"token\": \"bk50n8-...\",\n    \"new_password\": \"NewSecurePassword123!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/{{apiVersion}}/auth/password/reset/",
							"host": ["{{baseUrl}}"],
							"path": ["{{apiVersion}}", "auth", "password", "reset", ""]
						},
						"description": "Reset password using token from email. UID is base64 encoded user ID."
					},
					"response": []
				},
				{
					"name": "Change Password",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{tenantAccessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Host",
								"value": "{{tenantSubdomain}}.localhost:8000"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"old_password\": \"OldPassword123!\",\n    \"new_password\": \"NewSecurePassword456!\"\n}"
						},
						"url": {
							"raw": "http://{{tenantSubdomain}}.localhost:8000/{{apiVersion}}/auth/password/change/",
							"host": ["{{tenantSubdomain}}.localhost"],
							"port": "8000",
							"path": ["{{apiVersion}}", "auth", "password", "change", ""]
						},
						"description": "Change password for authenticated user. Requires old password verification. Blacklists all tokens on success."
					},
					"response": []
				}
			]
		},
