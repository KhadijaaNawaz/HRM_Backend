	"item": [
		{
			"name": "0. Platform Admin",
			"description": "Platform superuser endpoints for tenant management",
			"item": [
				{
					"name": "Public Signup (if enabled)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"organization_name\": \"Test Corp\",\n    \"subdomain\": \"test{{$timestamp}}\",\n    \"email\": \"admin@test.com\",\n    \"password\": \"TenantAdmin123!\",\n    \"first_name\": \"Test\",\n    \"last_name\": \"Admin\",\n    \"phone\": \"+1234567890\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/{{apiVersion}}/auth/signup/",
							"host": ["{{baseUrl}}"],
							"path": ["{{apiVersion}}", "auth", "signup", ""]
						},
						"description": "Public signup endpoint. Only works when PUBLIC_SIGNUP_ENABLED=true. Returns 403 when disabled."
					},
					"response": []
				},
				{
					"name": "Login as Platform Superuser",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.collectionVariables.set('adminAccessToken', response.access);",
									"    pm.collectionVariables.set('refreshToken', response.refresh);",
									"    console.log('Admin token saved');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@platform.com\",\n    \"password\": \"Admin123!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/{{apiVersion}}/auth/login/",
							"host": ["{{baseUrl}}"],
							"path": ["{{apiVersion}}", "auth", "login", ""]
						}
					},
					"response": []
				},
				{
					"name": "Create New Tenant",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    pm.collectionVariables.set('organizationId', response.organization.id);",
									"    pm.collectionVariables.set('tenantAccessToken', response.access);",
									"    pm.collectionVariables.set('tenantSubdomain', response.organization.subdomain);",
									"    console.log('Tenant created:', response.organization.name);",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminAccessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"organization_name\": \"Acme Corporation\",\n    \"subdomain\": \"acme{{$timestamp}}\",\n    \"email\": \"admin@acme.com\",\n    \"password\": \"TenantAdmin123!\",\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"phone\": \"+1234567890\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/{{apiVersion}}/admin/create-tenant/",
							"host": ["{{baseUrl}}"],
							"path": ["{{apiVersion}}", "admin", "create-tenant", ""]
						},
						"description": "Create a new tenant. Only accessible by platform superusers (is_superuser=True). Bypasses all public signup restrictions."
					},
					"response": []
				},
				{
					"name": "List All Tenants",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminAccessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/{{apiVersion}}/admin/tenants/?page=1&page_size=20&status=active&search=",
							"host": ["{{baseUrl}}"],
							"path": ["{{apiVersion}}", "admin", "tenants", ""],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "page_size",
									"value": "20"
								},
								{
									"key": "status",
									"value": "active",
									"description": "Filter by status: active, suspended, pending"
								},
								{
									"key": "search",
									"value": "",
									"description": "Search by name or subdomain"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Tenant Details",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminAccessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/{{apiVersion}}/admin/tenants/{{organizationId}}/",
							"host": ["{{baseUrl}}"],
							"path": ["{{apiVersion}}", "admin", "tenants", "{{organizationId}}", ""]
						}
					},
					"response": []
				},
				{
					"name": "Update Tenant",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminAccessToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated Organization Name\",\n    \"subdomain\": \"updated-subdomain\"\n}"
