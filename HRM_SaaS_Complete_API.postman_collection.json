		{
			"key": "apiVersion",
			"value": "api/v1",
			"type": "string"
		},
		{
			"key": "adminAccessToken",
			"value": "",
			"type": "string",
			"description": "Platform superuser access token"
		},
		{
			"key": "tenantAccessToken",
			"value": "",
			"type": "string",
			"description": "Tenant admin access token"
		},
		{
			"key": "employeeAccessToken",
			"value": "",
			"type": "string",
			"description": "Employee access token"
		},
		{
			"key": "tenantSubdomain",
			"value": "acme",
			"type": "string"
		},
		{
			"key": "organizationId",
			"value": "",
			"type": "string"
		},
		{
			"key": "userId",
			"value": "",
			"type": "string"
		},
		{
			"key": "roleId",
			"value": "",
			"type": "string"
		},
		{
			"key": "inviteId",
			"value": "",
			"type": "string"
		},
		{
			"key": "inviteToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "attendanceId",
			"value": "",
			"type": "string"
		},
		{
			"key": "auditLogId",
			"value": "",
			"type": "string"
		},
		{
			"key": "refreshToken",
			"value": "",
			"type": "string"
		}
